{
  "name": "battle-sim",
  "version": "1.0.0",
  "description": "A realistic battle simulator",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
